{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "watchAssets": true,
    "assets": [
      {
        "include": "common/services/mail/templates/**/*.hbs",
        "outDir": "dist/src"
      },
      {
        "include": "i18n/**/*",
        "outDir": "dist/src"
      }
    ]
  }
}
