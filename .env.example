# Server Configuration
PORT=5001
NODE_ENV=development
CORS_ORIGIN=*
# Fallback language for localized responses: en | ru | uz
DEFAULT_LANGUAGE=en

# Database Configuration
DATABASE_URL="postgresql://username:password@localhost:5432/database_name"

# JWT Configuration
JWT_ACCESS_TOKEN_SECRET=change-me-to-a-long-random-string
JWT_REFRESH_TOKEN_SECRET=change-me-to-a-different-long-random-string
JWT_ACCESS_TOKEN_EXPIRATION=15m
JWT_REFRESH_TOKEN_EXPIRATION=7d

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:5001/api/v1/auth/google/callback

# Email (SMTP) Configuration
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your-email@gmail.com
MAIL_PASS=your-app-password

# Swagger UI Basic Auth (protects /api/docs)
SWAGGER_USER=admin
SWAGGER_PASSWORD=admin

# MinIO / S3 Configuration
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false
MINIO_BUCKET=uploads

# Content seeder (`yarn seed:content`). Pulls the upstream CMS once, downloads
# each file into LOCAL_IMPORT_DIR named by the new Files row id (ready to upload
# to MinIO by hand), and links content rows to those files by id.
IMPORT_SOURCE_BASE_URL=https://fic.uniplatforms.uz/api
LOCAL_IMPORT_DIR=./storage/imports

# Logging (Elasticsearch — optional; console logging is always on)
ELASTICSEARCH_NODE=
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=

# Seed admin account (used only by `yarn prisma:seed`)
SEED_ADMIN_EMAIL=user@example.com
SEED_ADMIN_PASSWORD=P@ssw0rd123

